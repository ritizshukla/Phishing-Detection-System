{
  "manifest_version": 3,
  "name": "Phishing Detector",
  "version": "1.0",

  "permissions": ["tabs", "scripting"],
  "host_permissions": [
    "http://127.0.0.1:8000/*",
    "<all_urls>"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup/popup.html"
  }
}